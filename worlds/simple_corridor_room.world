    <model name="left_room_floor_marker">
      <static>true</static>
      <pose>5 4 0.013 0 0 0</pose>
      <link name="link">
        <visual name="visual"><geometry><box><size>4.0 4.0 0.02</size></box></geometry><material><ambient>0.20 0.45 0.70 0.18</ambient><diffuse>0.20 0.45 0.70 0.18</diffuse></material><transparency>0.78</transparency></visual>
