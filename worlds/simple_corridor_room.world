<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="simple_corridor_room">
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <include>
      <uri>model://sun</uri>
    </include>

    <gravity>0 0 -9.81</gravity>
    <magnetic_field>6.0e-6 2.3e-5 -4.2e-5</magnetic_field>
    <atmosphere type="adiabatic"/>

    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <scene>
      <ambient>0.48 0.48 0.48 1</ambient>
      <background>0.70 0.78 0.86 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- START / SAFE_EXIT: takeoff, return, and landing area. Visual only. -->
    <model name="start_safe_exit_marker">
      <static>true</static>
      <pose>0 0 0.012 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>2.2 2.2 0.02</size>
            </box>
          </geometry>
          <material>
            <ambient>0.05 0.32 0.95 0.40</ambient>
            <diffuse>0.05 0.32 0.95 0.40</diffuse>
          </material>
          <transparency>0.58</transparency>
        </visual>
      </link>
    </model>

    <!-- Main corridor: approximately x=-0.5..15.5 and y=-2..2. -->
    <model name="corridor_upper_wall_a">
      <static>true</static>
      <pose>1.65 2.15 1.0 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>4.3 0.3 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>4.3 0.3 2.0</size></box></geometry><material><ambient>0.60 0.60 0.58 1</ambient><diffuse>0.60 0.60 0.58 1</diffuse></material></visual>
      </link>
    </model>

    <model name="corridor_upper_wall_b">
      <static>true</static>
      <pose>8.85 2.15 1.0 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>5.7 0.3 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>5.7 0.3 2.0</size></box></geometry><material><ambient>0.60 0.60 0.58 1</ambient><diffuse>0.60 0.60 0.58 1</diffuse></material></visual>
      </link>
    </model>

    <model name="corridor_upper_wall_c">
      <static>true</static>
      <pose>14.75 2.15 1.0 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>1.5 0.3 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>1.5 0.3 2.0</size></box></geometry><material><ambient>0.60 0.60 0.58 1</ambient><diffuse>0.60 0.60 0.58 1</diffuse></material></visual>
      </link>
    </model>

    <model name="corridor_lower_wall_a">
      <static>true</static>
      <pose>3.65 -2.15 1.0 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>8.3 0.3 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>8.3 0.3 2.0</size></box></geometry><material><ambient>0.60 0.60 0.58 1</ambient><diffuse>0.60 0.60 0.58 1</diffuse></material></visual>
      </link>
